---
import BaseLayout from "../layouts/BaseLayout.astro";
import SessionGroup from "../components/SessionGroup.astro";
import { getSessionGroupCategory } from "../data/sessions";
import { getHomepageContent } from "../lib/content";

const homepageContent = await getHomepageContent();
const { site, sessionGroups } = homepageContent.content;
const pageTitle = site.hero.title;
const pageDescription = site.hero.description;
const workshopGroups = sessionGroups.filter((group) => getSessionGroupCategory(group) === "workshop");
const focusGroups = sessionGroups.filter((group) => getSessionGroupCategory(group) === "focus");
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="min-h-screen flex flex-col">
    <header class="relative flex min-h-[70vh] items-center justify-center bg-[#733a84] px-4 py-12 text-center sm:py-0">
      <div class="max-w-4xl w-full px-4 sm:px-6 lg:px-8">
        <div class="max-w-2xl mx-auto">
          <img
            src={site.hero.imageSrc}
            alt={site.hero.imageAlt}
            width="600"
            height="600"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="mx-auto w-full max-w-xs sm:max-w-sm md:max-w-md lg:max-w-lg"
          />
          <h1 class="mt-6 text-2xl sm:text-3xl md:text-4xl font-bold text-white leading-tight">
            {site.hero.title}
          </h1>
          <p class="mt-4 text-white text-base sm:text-lg md:text-xl max-w-2xl mx-auto">
            {site.hero.description}
          </p>
        </div>
        <div aria-hidden="true" class="mt-8 motion-safe:animate-bounce motion-reduce:animate-none">
          <svg
            class="w-6 h-6 mx-auto text-white"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="m19 9-7 7-7-7"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
            ></path>
          </svg>
        </div>
      </div>
    </header>

    <main
      id="main-content"
      tabindex="-1"
      class="relative z-20 bg-white rounded-t-xl h-auto px-4 sm:px-6 lg:px-8 py-8 w-full max-w-7xl mx-auto focus:outline-none"
    >
      <section id="conference-form" aria-labelledby="conference-survey-heading" class="mb-12 text-center">
        <div class="bg-white rounded-lg shadow-lg p-4 sm:p-6 border border-gray-200 hover:shadow-2xl transition-all mx-auto max-w-3xl duration-300 hover:-translate-y-[.125rem]">
          <h2 id="conference-survey-heading" class="font-semibold mb-3 text-gray-800 text-xl">
            {site.survey.title}
          </h2>
          <p class="text-gray-600 mb-5">
            {site.survey.description}
          </p>
          <a
            href={site.survey.feedbackUrl}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Provide feedback for ${site.survey.title} (opens in a new tab)`}
            class="block w-full cursor-pointer rounded-lg bg-[#733a84] px-4 py-3 text-center font-medium text-white shadow-md transition-all hover:bg-purple-700 hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#733a84]"
          >
            {site.survey.buttonText}
          </a>
        </div>
      </section>

      {workshopGroups.map((group) => <SessionGroup group={group} />)}

      {workshopGroups.length > 0 && focusGroups.length > 0 && (
        <div class="mx-auto my-8 w-full max-w-3xl px-2 sm:px-0" aria-hidden="true">
          <div class="border-t border-gray-300"></div>
        </div>
      )}

      {focusGroups.map((group) => <SessionGroup group={group} />)}
    </main>

    <footer class="bg-[#733a84] text-white py-8 px-4 text-center">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-lg font-medium mb-3">15th Annual Health Professions Conference</p>
        <p class="text-sm sm:text-base max-w-2xl mx-auto">
          For further assistance, questions, or concerns please contact
          <a
            href="mailto:crexach@mtsac.edu"
            class="cursor-pointer break-words text-blue-300 underline transition-colors hover:text-purple-200 focus-visible:rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            crexach@mtsac.edu
          </a>
        </p>
        <div class="flex flex-col sm:flex-row justify-center items-center mt-6 mb-4 space-y-3 sm:space-y-0 sm:space-x-8">
          <a
            href="https://www.mtsac.edu/caduceus/"
            class="cursor-pointer text-sm transition-colors hover:text-purple-200 focus-visible:rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:text-base"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Caduceus Club Website (opens in a new tab)"
          >
            Caduceus Club Website
          </a>
          <span class="hidden sm:inline text-gray-300">•</span>
          <a
            href="https://www.instagram.com/mtsac.caduceusclub"
            class="cursor-pointer text-sm transition-colors hover:text-purple-200 focus-visible:rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:text-base"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram (opens in a new tab)"
          >
            Instagram
          </a>
          <span class="hidden sm:inline text-gray-300">•</span>
          <a
            href="/cms"
            class="cursor-pointer text-sm transition-colors hover:text-purple-200 focus-visible:rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white sm:text-base"
          >
            Dashboard / CMS
          </a>
        </div>
        <div class="mt-6">
          <a
            href="https://bentgarcia.com"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block cursor-pointer rounded-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
            aria-label="Website made by Benjamin Garcia (opens in a new tab)"
          >
            <img
              src="/static/favicon.svg"
              alt=""
              aria-hidden="true"
              width="20"
              height="20"
              loading="lazy"
              decoding="async"
              class="mx-auto opacity-80 hover:opacity-100 transition-opacity"
            />
          </a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout>
