---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAuthenticatedSupabaseUser,
  isAdminAuthConfigured,
  setSupabaseSession,
} from "../../lib/auth";

const { user, refreshedSession } = await getAuthenticatedSupabaseUser(Astro.cookies);

if (refreshedSession) {
  setSupabaseSession(Astro.cookies, refreshedSession);
}

const authConfigured = isAdminAuthConfigured();
const errorMessage = Astro.url.searchParams.get("error");
const statusCode = Astro.url.searchParams.get("status");
const hasActiveSession = Boolean(user);
const inputClass =
  "mt-2 w-full rounded-lg border border-gray-300 bg-white px-3 py-2.5 text-sm text-gray-900 shadow-sm outline-none transition focus:border-gray-400 focus:ring-2 focus:ring-gray-200";
const primaryButtonClass =
  "inline-flex w-full cursor-pointer items-center justify-center rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-gray-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-900 disabled:cursor-not-allowed disabled:bg-gray-300";
const secondaryButtonClass =
  "inline-flex cursor-pointer items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 transition hover:border-gray-400 hover:bg-gray-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gray-400";

function getStatusMessage(code: string | null) {
  switch (code) {
    case "invite-accepted":
      return "Your invite was accepted. Create a password to finish dashboard access.";
    default:
      return null;
  }
}

const statusMessage = getStatusMessage(statusCode);
---

<BaseLayout title="Set Dashboard Password" description="Finish your dashboard invite and create a password.">
  <main
    id="main-content"
    class="flex min-h-screen items-center justify-center bg-[#f5f5f3] px-4 py-8 sm:px-6 lg:px-8"
  >
    <section class="w-full max-w-md rounded-xl border border-gray-200 bg-white p-6 shadow-sm sm:p-8">
      <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-semibold text-gray-900">Set Password</h1>
        <p class="text-sm leading-6 text-gray-600">
          Finish the invite flow by setting the password that this admin will use for the dashboard.
        </p>
      </div>

      <div class="mt-6 space-y-3">
        {!authConfigured && (
          <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            Supabase auth is not configured. Set <code>NEXT_PUBLIC_SUPABASE_URL</code> and <code>NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY</code>.
          </div>
        )}

        {statusMessage && (
          <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
            {statusMessage}
          </div>
        )}

        {errorMessage && (
          <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
            {errorMessage}
          </div>
        )}
      </div>

      {
        hasActiveSession ? (
          <form action="/api/auth/set-password" method="post" class="mt-6 space-y-5">
            <label class="block text-sm font-medium text-gray-700">
              New Password
              <input
                name="password"
                type="password"
                autocomplete="new-password"
                required
                minlength="8"
                class={inputClass}
                placeholder="••••••••"
              />
            </label>

            <label class="block text-sm font-medium text-gray-700">
              Confirm Password
              <input
                name="confirmPassword"
                type="password"
                autocomplete="new-password"
                required
                minlength="8"
                class={inputClass}
                placeholder="••••••••"
              />
            </label>

            <button type="submit" class={primaryButtonClass} disabled={!authConfigured}>
              Save Password
            </button>
          </form>
        ) : (
          <div id="invite-activation-panel" class="mt-6 space-y-4">
            <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-4 text-sm text-gray-700">
              <p id="invite-activation-message">
                Open this page from the invite email. If the invite session is present, it will be activated automatically.
              </p>
            </div>
          </div>
        )
      }

      <div class="mt-6 flex justify-end border-t border-gray-200 pt-5">
        <a href="/cms/login" class={secondaryButtonClass}>
          Back to Login
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const activationPanel = document.getElementById("invite-activation-panel");
  const activationMessage = document.getElementById("invite-activation-message");
  const searchParams = new URLSearchParams(window.location.search);

  if (activationPanel && activationMessage) {
    const hashParams = new URLSearchParams(window.location.hash.slice(1));
    const accessToken = hashParams.get("access_token");
    const refreshToken = hashParams.get("refresh_token");
    const tokenHash = searchParams.get("token_hash");
    const inviteType = searchParams.get("type");

    if (tokenHash && inviteType === "invite") {
      window.location.replace(`/api/auth/accept-invite?${searchParams.toString()}`);
    } else if (accessToken && refreshToken) {
      activationMessage.textContent = "Activating invite session...";

      const formData = new FormData();
      formData.set("accessToken", accessToken);
      formData.set("refreshToken", refreshToken);

      fetch("/api/auth/accept-invite", {
        method: "POST",
        body: formData,
      })
        .then(async (response) => {
          const payload = await response.json().catch(() => ({ ok: false }));

          if (!response.ok || !payload.ok) {
            throw new Error(payload.error || "This invite link is invalid or expired.");
          }

          window.location.replace("/cms/set-password?status=invite-accepted");
        })
        .catch((error) => {
          const message =
            error instanceof Error ? error.message : "This invite link is invalid or expired.";
          activationMessage.textContent = message;
          activationPanel.className =
            "mt-6 rounded-lg border border-red-200 bg-red-50 px-4 py-4 text-sm text-red-800";
        });
    }
  }
</script>
